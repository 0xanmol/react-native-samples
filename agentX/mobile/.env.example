# Server connection
# Android emulator → host machine: use 10.0.2.2
# Physical device on same WiFi: use your machine's LAN IP (e.g. 192.168.1.42)
# Production: use your deployed server URL (https://...)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080
EXPO_PUBLIC_WS_URL=ws://10.0.2.2:8080/ws

# Must match API_KEY in server/.env
EXPO_PUBLIC_API_KEY=helloworld
